<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ljzxzxl.ChargeLimiter.Helper</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Library/PrivilegedHelperTools/charge-limit-helperd</string>
    <string>--daemon</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Library/Logs/ChargeLimiter/helper.log</string>

  <key>StandardErrorPath</key>
  <string>/Library/Logs/ChargeLimiter/helper.err.log</string>
</dict>
</plist>
